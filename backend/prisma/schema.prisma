enum AccountType {
  asset
  liability
  equity
  revenue
  expense
  
  @@map("account_type")
}

enum PeriodType {
  monthly
  quarterly
  annually
  
  @@map("period_type")
}

enum BudgetStatus {
  draft
  submitted
  approved
  active
  closed
  
  @@map("budget_status")
}

enum ARStatus {
  outstanding
  partial
  paid
  overdue
  written_off
  
  @@map("ar_status")
}

enum APStatus {
  outstanding
  partial
  paid
  overdue
  
  @@map("ap_status")
}

enum BankAccountType {
  checking
  savings
  credit_line
  money_market
  
  @@map("bank_account_type")
}

enum ForecastType {
  revenue
  expense
  cashflow
  profit
  
  @@map("forecast_type")
}

enum ForecastStatus {
  draft
