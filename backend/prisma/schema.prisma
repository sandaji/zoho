  @@map("alert_type")
}

enum AlertSeverity {
  low
  medium
  high
  critical
  
  @@map("alert_severity")
}

enum AlertStatus {
  active
  acknowledged
  resolved
  dismissed
  
  @@map("alert_status")
}

enum TaxType {
  vat
  income_tax
  payroll_tax
  withholding_tax
  sales_tax
  
  @@map("tax_type")
}

enum TaxStatus {
  pending
  filed
  paid
  overdue
  
  @@map("tax_status")
}



// ============================================================================
// HR & LEAVE MANAGEMENT MODELS
// ============================================================================

/// Types of Leave (e.g., Annual, Sick, Unpaid)
model LeaveType {
  id          String   @id @default(cuid())
  name        String   @unique // e.g., "Annual Leave", "Sick Leave"
  description String?
  daysAllowed Int      // Default days per year
  carryOver   Boolean  @default(false)
  
  allocations LeaveAllocation[]
  requests    LeaveRequest[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("leave_types")
}

/// Leave Allocation - Tracks days allowed vs used per user per year
model LeaveAllocation {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  leaveTypeId String
  leaveType   LeaveType @relation(fields: [leaveTypeId], references: [id])
  
  year        Int       // e.g., 2024
  allocated   Int       // Total days given
  used        Int       @default(0) // Days consumed
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, leaveTypeId, year])
  @@map("leave_allocations")
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

/// Leave Requests
model LeaveRequest {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  leaveTypeId String
  leaveType   LeaveType   @relation(fields: [leaveTypeId], references: [id])
  
  startDate   DateTime
  endDate     DateTime
  days        Int         // Calculated working days
  reason      String?
  
  status      LeaveStatus @default(PENDING)
  
  processedBy String?     // User ID of approver/rejecter
  processedAt DateTime?
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("leave_requests")
  @@index([userId])
  @@index([status])
}

// ============================================================================
// RECRUITMENT MODELS
// ============================================================================

enum JobPostingStatus {
  DRAFT
  PUBLISHED
  CLOSED
  ARCHIVED
}

model JobPosting {
  id          String           @id @default(cuid())
  title       String
  description String
  department  String
  location    String?
  type        String?          // e.g., "Full-time", "Contract"
  status      JobPostingStatus @default(DRAFT)
  
  applicants  Applicant[]
  
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("job_postings")
}

enum ApplicantStatus {
  NEW
  REVIEWING
  INTERVIEWING
  OFFERED
  HIRED
  REJECTED
}

model Applicant {
  id           String          @id @default(cuid())
  name         String
  email        String
  phone        String?
  resumeUrl    String?
  status       ApplicantStatus @default(NEW)
  notes        String?
  
  jobPostingId String
  jobPosting   JobPosting      @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  
  interviews   Interview[]
  
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@map("applicants")
  @@index([jobPostingId])
}

enum InterviewStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

model Interview {
  id            String          @id @default(cuid())
  applicantId   String
  applicant     Applicant       @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  interviewerId String
  interviewer   User            @relation("Interviewer", fields: [interviewerId], references: [id])
  
  scheduledAt   DateTime
  feedback      String?
  rating        Int?            // e.g., 1-5
  status        InterviewStatus @default(SCHEDULED)
  
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@map("interviews")
  @@index([applicantId])
  @@index([interviewerId])
}

// ============================================================================
// PERFORMANCE MODELS
// ============================================================================

enum PerformanceStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  OVERDUE
}

model Goal {
  id          String            @id @default(cuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  title       String
  description String?
  targetDate  DateTime?
  progress    Int               @default(0) // 0-100
  status      PerformanceStatus @default(NOT_STARTED)
  
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@map("performance_goals")
  @@index([userId])
}

model PerformanceEvaluation {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation("Evaluatee", fields: [userId], references: [id])
  evaluatorId String
  evaluator   User     @relation("Evaluator", fields: [evaluatorId], references: [id])
  
  period      String   // e.g., "Q4 2024", "Annual 2024"
  date        DateTime @default(now())
  ratings     Json?    // Structured ratings for different competencies
  comments    String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("performance_evaluations")
  @@index([userId])
  @@index([evaluatorId])
}

model DevelopmentPlan {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  title       String
  description String
  status      String   @default("ACTIVE")
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("development_plans")
  @@index([userId])
}

// ============================================================================
// BENEFITS MODELS
// ============================================================================

model Benefit {
  id          String              @id @default(cuid())
  name        String
  type        String              // e.g., "Health", "Dental", "Retirement"
  description String?
  provider    String?
  
  enrollments BenefitEnrollment[]
  
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@map("benefits")
}

model BenefitEnrollment {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  benefitId   String
  benefit     Benefit  @relation(fields: [benefitId], references: [id], onDelete: Cascade)
  
  enrolledAt  DateTime @default(now())
  status      String   @default("ACTIVE")
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, benefitId])
  @@map("benefit_enrollments")
  @@index([userId])
  @@index([benefitId])
}

// ============================================================================
// RBAC MODELS
// ============================================================================

model Module {
  id          String       @id @default(cuid())
  name        String       @unique // e.g., "Finance", "HR"
  code        String       @unique // e.g., "finance"
  permissions Permission[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("modules")
}

model Permission {
  id          String           @id @default(cuid())
  name        String           // e.g., "Create Invoice"
  code        String           @unique // e.g., "finance.invoice.create"
  moduleId    String
  module      Module           @relation(fields: [moduleId], references: [id])
  roles       RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("permissions")
  @@index([moduleId])
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique // e.g., "Finance Manager"
  code        String           @unique // e.g., "finance_manager"
  description String?
  isSystem    Boolean          @default(false) // Prevents deletion of core ERP roles
  permissions RolePermission[]
  users       RoleAssignment[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("roles")
}

model RolePermission {
  roleId       String
  role         Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission  @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  scope        AccessScope @default(BRANCH)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

enum AccessScope {
  GLOBAL
  BRANCH
  OWN
}

model RoleAssignment {
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId String
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

// ============================================================================
// AUDIT LOG MODEL
// ============================================================================

model AuditLog {
  id         String      @id @default(cuid())
  entityType String
  entityId   String
  action     AuditAction
  userId     String?
  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  changes    Json
  ipAddress  String?
  timestamp  DateTime    @default(now())

  @@map("audit_logs")
  @@index([entityType, entityId])
  @@index([userId])
  @@index([timestamp])
}
